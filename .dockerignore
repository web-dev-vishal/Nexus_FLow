# Dependencies — reinstalled inside the container
node_modules/
.kilo/

# Logs — written at runtime, not needed in image
logs/
*.log

# Environment files — never bake secrets into images
.env
.env.*
!.env.example

# Dev/test artifacts
audit-report*.json
test_output.txt
coverage/
.nyc_output/

# Git
.git/
.gitignore

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
