{
  "info": {
    "name": "NexusFlow API",
    "description": "Complete API collection for NexusFlow. Flow: Health → Register → Verify Email → Login (auto-saves tokens) → use all other endpoints.\n\nVariables auto-saved by test scripts: accessToken, refreshToken, workspaceId, channelId, messageId, dmId, workflowId, executionId, webhookId, transactionId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000",      "type": "string" },
    { "key": "email",        "value": "testuser@example.com",       "type": "string" },
    { "key": "accessToken",  "value": "",                           "type": "string" },
    { "key": "refreshToken", "value": "",                           "type": "string" },
    { "key": "workspaceId",  "value": "",                           "type": "string" },
    { "key": "channelId",    "value": "",                           "type": "string" },
    { "key": "messageId",    "value": "",                           "type": "string" },
    { "key": "dmId",         "value": "",                           "type": "string" },
    { "key": "workflowId",   "value": "",                           "type": "string" },
    { "key": "executionId",  "value": "",                           "type": "string" },
    { "key": "webhookId",    "value": "",                           "type": "string" },
    { "key": "transactionId","value": "",                           "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "00 - Health",
      "description": "Health check endpoints. No auth required.",
      "item": [
        {
          "name": "Basic Health",
          "request": { "auth": {"type":"noauth"}, "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/health","host":["{{baseUrl}}"],"path":["api","health"]} }
        },
        {
          "name": "Liveness Probe",
          "request": { "auth": {"type":"noauth"}, "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/health/live","host":["{{baseUrl}}"],"path":["api","health","live"]} }
        },
        {
          "name": "Readiness Probe",
          "request": { "auth": {"type":"noauth"}, "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/health/ready","host":["{{baseUrl}}"],"path":["api","health","ready"]} }
        },
        {
          "name": "Detailed Health",
          "request": { "auth": {"type":"noauth"}, "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/health/detailed","host":["{{baseUrl}}"],"path":["api","health","detailed"]} }
        },
        {
          "name": "API Info",
          "request": { "auth": {"type":"noauth"}, "method": "GET",
            "url": {"raw":"{{baseUrl}}/api","host":["{{baseUrl}}"],"path":["api"]} }
        },
        {
          "name": "Prometheus Metrics",
          "request": { "auth": {"type":"noauth"}, "method": "GET",
            "url": {"raw":"{{baseUrl}}/metrics","host":["{{baseUrl}}"],"path":["metrics"]} }
        }
      ]
    },
    {
      "name": "01 - Auth",
      "description": "Register → Verify Email → Login. Login auto-saves accessToken and refreshToken.",
      "item": [
        {
          "name": "Register",
          "event": [{"listen":"test","script":{"exec":["pm.test('Status 201', () => pm.response.to.have.status(201));"]}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/register","host":["{{baseUrl}}"],"path":["api","auth","register"]},
            "body": {"mode":"raw","raw":"{\n  \"username\": \"testuser\",\n  \"email\": \"{{email}}\",\n  \"password\": \"Password123!\"\n}"} }
        },
        {
          "name": "Verify Email (token from email link)",
          "request": { "auth": {"type":"noauth"}, "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer PASTE_VERIFY_TOKEN_HERE"}],
            "url": {"raw":"{{baseUrl}}/api/auth/verify-email","host":["{{baseUrl}}"],"path":["api","auth","verify-email"]} }
        },
        {
          "name": "Resend Verification Email",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/resend-verification","host":["{{baseUrl}}"],"path":["api","auth","resend-verification"]},
            "body": {"mode":"raw","raw":"{\n  \"email\": \"{{email}}\"\n}"} }
        },
        {
          "name": "Login",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 200) {",
            "  const b = pm.response.json();",
            "  pm.collectionVariables.set('accessToken', b.accessToken);",
            "  pm.collectionVariables.set('refreshToken', b.refreshToken);",
            "  pm.test('Got tokens', () => pm.expect(b.accessToken).to.be.a('string'));",
            "}"
          ]}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/login","host":["{{baseUrl}}"],"path":["api","auth","login"]},
            "body": {"mode":"raw","raw":"{\n  \"email\": \"{{email}}\",\n  \"password\": \"Password123!\"\n}"} }
        },
        {
          "name": "Get Profile",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/auth/profile","host":["{{baseUrl}}"],"path":["api","auth","profile"]} }
        },
        {
          "name": "Update Profile",
          "request": { "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/profile","host":["{{baseUrl}}"],"path":["api","auth","profile"]},
            "body": {"mode":"raw","raw":"{\n  \"username\": \"updateduser\"\n}"} }
        },
        {
          "name": "Refresh Access Token",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('accessToken', pm.response.json().accessToken);",
            "}"
          ]}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{refreshToken}}"}],
            "url": {"raw":"{{baseUrl}}/api/auth/refresh-token","host":["{{baseUrl}}"],"path":["api","auth","refresh-token"]} }
        },
        {
          "name": "Forgot Password (sends OTP)",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/forgot-password","host":["{{baseUrl}}"],"path":["api","auth","forgot-password"]},
            "body": {"mode":"raw","raw":"{\n  \"email\": \"{{email}}\"\n}"} }
        },
        {
          "name": "Verify OTP",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/verify-otp/{{email}}","host":["{{baseUrl}}"],"path":["api","auth","verify-otp","{{email}}"]},
            "body": {"mode":"raw","raw":"{\n  \"otp\": \"123456\"\n}"} }
        },
        {
          "name": "Change Password",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/change-password/{{email}}","host":["{{baseUrl}}"],"path":["api","auth","change-password","{{email}}"]},
            "body": {"mode":"raw","raw":"{\n  \"newPassword\": \"NewPassword123!\",\n  \"confirmPassword\": \"NewPassword123!\"\n}"} }
        },
        {
          "name": "Logout",
          "request": { "method": "POST",
            "url": {"raw":"{{baseUrl}}/api/auth/logout","host":["{{baseUrl}}"],"path":["api","auth","logout"]} }
        }
      ]
    },
    {
      "name": "02 - Workspaces",
      "description": "Create workspace first — workspaceId is auto-saved.",
      "item": [
        {
          "name": "Create Workspace",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('workspaceId', pm.response.json().workspace._id);",
            "}"
          ]}}],
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces","host":["{{baseUrl}}"],"path":["api","workspaces"]},
            "body": {"mode":"raw","raw":"{\n  \"name\": \"My Team\",\n  \"description\": \"Our main workspace\",\n  \"icon\": \"\"\n}"} }
        },
        {
          "name": "List My Workspaces",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces","host":["{{baseUrl}}"],"path":["api","workspaces"]} }
        },
        {
          "name": "Get Workspace",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}"]} }
        },
        {
          "name": "Update Workspace",
          "request": { "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}"]},
            "body": {"mode":"raw","raw":"{\n  \"name\": \"My Team Updated\",\n  \"description\": \"Updated description\"\n}"} }
        },
        {
          "name": "Invite Member",
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/invite","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","invite"]},
            "body": {"mode":"raw","raw":"{\n  \"email\": \"colleague@example.com\",\n  \"role\": \"member\"\n}"} }
        },
        {
          "name": "List Members",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/members?page=1&limit=20","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","members"],"query":[{"key":"page","value":"1"},{"key":"limit","value":"20"}]} }
        },
        {
          "name": "Change Member Role",
          "request": { "method": "PATCH",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/members/MEMBER_USER_ID/role","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","members","MEMBER_USER_ID","role"]},
            "body": {"mode":"raw","raw":"{\n  \"role\": \"admin\"\n}"} }
        },
        {
          "name": "Remove Member",
          "request": { "method": "DELETE",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/members/MEMBER_USER_ID","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","members","MEMBER_USER_ID"]} }
        },
        {
          "name": "Workspace Stats",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/stats","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","stats"]} }
        },
        {
          "name": "Delete Workspace",
          "request": { "method": "DELETE",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}"]} }
        }
      ]
    },
    {
      "name": "03 - Channels",
      "description": "Channels live inside a workspace. channelId is auto-saved on create.",
      "item": [
        {
          "name": "Create Channel",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('channelId', pm.response.json().channel._id);",
            "}"
          ]}}],
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels"]},
            "body": {"mode":"raw","raw":"{\n  \"name\": \"engineering\",\n  \"description\": \"Engineering team channel\",\n  \"type\": \"public\"\n}"} }
        },
        {
          "name": "List Channels",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels"]} }
        },
        {
          "name": "Get Channel",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}"]} }
        },
        {
          "name": "Update Channel",
          "request": { "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}"]},
            "body": {"mode":"raw","raw":"{\n  \"description\": \"Updated description\",\n  \"topic\": \"Current sprint: v2.0\"\n}"} }
        },
        {
          "name": "Join Channel",
          "request": { "method": "POST",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/join","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","join"]} }
        },
        {
          "name": "Leave Channel",
          "request": { "method": "POST",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/leave","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","leave"]} }
        },
        {
          "name": "Search Messages in Channel",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/search?q=hello&limit=20","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","search"],"query":[{"key":"q","value":"hello"},{"key":"limit","value":"20"}]} }
        },
        {
          "name": "Pin Message",
          "request": { "method": "POST",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/pin/{{messageId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","pin","{{messageId}}"]} }
        },
        {
          "name": "Unpin Message",
          "request": { "method": "DELETE",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/pin/{{messageId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","pin","{{messageId}}"]} }
        },
        {
          "name": "Delete Channel",
          "request": { "method": "DELETE",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}"]} }
        }
      ]
    },
    {
      "name": "04 - Messages",
      "description": "Send, edit, delete, react, thread, bookmark messages. messageId auto-saved on send.",
      "item": [
        {
          "name": "Send Message",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('messageId', pm.response.json().message._id);",
            "}"
          ]}}],
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages"]},
            "body": {"mode":"raw","raw":"{\n  \"content\": \"Hello team! \"\n}"} }
        },
        {
          "name": "List Messages",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages?limit=50","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages"],"query":[{"key":"limit","value":"50"}]} }
        },
        {
          "name": "List Messages (cursor pagination)",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages?before={{messageId}}&limit=50","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages"],"query":[{"key":"before","value":"{{messageId}}"},{"key":"limit","value":"50"}]} }
        },
        {
          "name": "Get Single Message",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}"]} }
        },
        {
          "name": "Edit Message",
          "request": { "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}"]},
            "body": {"mode":"raw","raw":"{\n  \"content\": \"Hello team! (edited)\"\n}"} }
        },
        {
          "name": "Delete Message",
          "request": { "method": "DELETE",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}"]} }
        },
        {
          "name": "Add Reaction",
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/react","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}","react"]},
            "body": {"mode":"raw","raw":"{\n  \"emoji\": \"+1\"\n}"} }
        },
        {
          "name": "Remove Reaction",
          "request": { "method": "DELETE",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/react","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}","react"]},
            "body": {"mode":"raw","raw":"{\n  \"emoji\": \"+1\"\n}"} }
        },
        {
          "name": "Reply in Thread",
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/thread","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}","thread"]},
            "body": {"mode":"raw","raw":"{\n  \"content\": \"This is a thread reply!\"\n}"} }
        },
        {
          "name": "Get Thread Replies",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/thread","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}","thread"]} }
        },
        {
          "name": "Bookmark Message",
          "request": { "method": "POST",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/bookmark","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}","bookmark"]} }
        },
        {
          "name": "Remove Bookmark",
          "request": { "method": "DELETE",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/bookmark","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","channels","{{channelId}}","messages","{{messageId}}","bookmark"]} }
        },
        {
          "name": "Get Bookmarks",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/bookmarks?page=1&limit=20","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","bookmarks"],"query":[{"key":"page","value":"1"},{"key":"limit","value":"20"}]} }
        },
        {
          "name": "Search Workspace",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/search?q=hello&limit=20","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","search"],"query":[{"key":"q","value":"hello"},{"key":"limit","value":"20"}]} }
        }
      ]
    },
    {
      "name": "05 - Direct Messages",
      "description": "DMs nested under /api/workspaces/:workspaceId/dms. dmId auto-saved on create.",
      "item": [
        {
          "name": "Start DM Conversation",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('dmId', pm.response.json().conversation._id);",
            "}"
          ]}}],
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/dms","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","dms"]},
            "body": {"mode":"raw","raw":"{\n  \"participantIds\": [\"RECIPIENT_USER_ID\"]\n}"} }
        },
        {
          "name": "List DM Conversations",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/dms","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","dms"]} }
        },
        {
          "name": "Get DM Conversation",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/dms/{{dmId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","dms","{{dmId}}"]} }
        },
        {
          "name": "Get DM Members",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/dms/{{dmId}}/members","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","dms","{{dmId}}","members"]} }
        },
        {
          "name": "Send DM Message",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('messageId', pm.response.json().message._id);",
            "}"
          ]}}],
          "request": { "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/dms/{{dmId}}/messages","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","dms","{{dmId}}","messages"]},
            "body": {"mode":"raw","raw":"{\n  \"content\": \"Hey! \"\n}"} }
        },
        {
          "name": "Get DM Messages",
          "request": { "method": "GET",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/dms/{{dmId}}/messages?limit=50","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","dms","{{dmId}}","messages"],"query":[{"key":"limit","value":"50"}]} }
        },
        {
          "name": "Close DM Conversation",
          "request": { "method": "DELETE",
            "url": {"raw":"{{baseUrl}}/api/workspaces/{{workspaceId}}/dms/{{dmId}}","host":["{{baseUrl}}"],"path":["api","workspaces","{{workspaceId}}","dms","{{dmId}}"]} }
        }
      ]
    },
    {
      "name": "06 - Workflows",
      "description": "Workflow automation. workflowId and executionId auto-saved.",
      "item": [
        {
          "name": "Create Workflow",
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('workflowId', pm.response.json().workflow._id);",
            "}"
          ]}}],
          "request": { "method": "POST",
